# ===========================================
# SmartTools.fun – Environment variables
# ===========================================
# Copy this file to .env.local (local dev) or set in Vercel → Settings → Environment Variables.

# -----------------------------------------------------------------------------
# Site (required for sitemap & robots in production)
# -----------------------------------------------------------------------------
# Your canonical site URL. Used by sitemap.xml and robots.txt.
# Set this in Vercel Production so the sitemap uses https://smarttools.fun
SITE_URL=https://smarttools.fun

# -----------------------------------------------------------------------------
# APIs (optional – only if you use these features)
# -----------------------------------------------------------------------------
# Google Generative AI – used by the AI Text Humanizer tool.
# Get a key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# -----------------------------------------------------------------------------
# Vercel (set automatically by Vercel – do not add these locally)
# -----------------------------------------------------------------------------
# VERCEL_URL=          # Deployment URL (e.g. smarttools.fun or *.vercel.app)
# VERCEL_ENV=          # production | preview | development
